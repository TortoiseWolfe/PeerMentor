#!/bin/bash

# SpecKit wrapper script
# Auto-installs SpecKit and initializes project on first run
# Run './specify update' to reinstall at the pinned SPEC_KIT_REF version
# (bump SPEC_KIT_REF below to move to a newer release)

set -euo pipefail
cd "$(dirname "$0")"

SPEC_KIT_REF=v0.9.5

# The compose service runs as the host user so generated files stay
# host-owned; HOST_UID/HOST_GID feed its `user:` mapping.
HOST_UID="$(id -u)" HOST_GID="$(id -g)"
export HOST_UID HOST_GID

install_speckit() {
    echo "Installing SpecKit ${SPEC_KIT_REF}..."
    docker compose run --rm speckit \
        uv tool install specify-cli --from "git+https://github.com/github/spec-kit.git@${SPEC_KIT_REF}" \
        || { rm -rf .speckit; echo "SpecKit install failed" >&2; exit 1; }
}

init_project() {
    echo "Initializing SpecKit project..."
    docker compose run --rm speckit \
        specify init --here --ai claude --force --ignore-agent-tools \
        || { rm -rf .specify; echo "SpecKit init failed" >&2; exit 1; }
}

if [ "${1:-}" = "update" ]; then
    echo "Removing old installation..."
    rm -rf .speckit .specify
    install_speckit
    init_project
    echo "Update complete!"
    exit 0
fi

# Test for the installed binary, not the directory: a failed install can
# leave a partial .speckit/ that would otherwise block reinstall forever.
if [ ! -x ".speckit/bin/specify" ]; then
    install_speckit
fi

if [ ! -d ".specify/memory" ]; then
    init_project
fi

docker compose run --rm speckit specify "$@"
